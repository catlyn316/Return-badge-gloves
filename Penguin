eatFishBtn.MouseButton1Click:Connect(function()
    toggles.eatFish = not toggles.eatFish

    if toggles.eatFish then
        eatFishBtn.Text = "解除"
        eatFishBtn.BackgroundColor3 = Color3.fromRGB(244, 67, 54)
        eatFishFrame.BackgroundColor3 = Color3.fromRGB(227, 242, 253)

        task.spawn(function()
            while toggles.eatFish do
                pcall(function()
                    local fishFolder = Workspace:FindFirstChild("Fih")
                    if not fishFolder then return end
                    local children = fishFolder:GetChildren()
                    if #children == 0 then return end
                    local target = children[math.random(1, #children)]
                    local part = getBasePart(target)
                    local char = player.Character
                    if char and char:FindFirstChild("HumanoidRootPart") and part then
                        char.HumanoidRootPart.CFrame = part.CFrame + Vector3.new(0, 3, 0)
                    end
                end)
                task.wait(0.1)
            end
        end)
    else
        eatFishBtn.Text = "啟動"
        eatFishBtn.BackgroundColor3 = Color3.fromRGB(70, 130, 200)
        eatFishFrame.BackgroundColor3 = Color3.fromRGB(248, 249, 250)
    end
end)

