local function createTab(text, index, total)
    local tab = Instance.new("TextButton")
    local tabWidth = 1 / total
    tab.Size = UDim2.new(tabWidth, -4, 1, -4)
    tab.Position = UDim2.new((index - 1) * tabWidth, 2, 0, 2)
    tab.BackgroundColor3 = Color3.fromRGB(200, 200, 200)
    tab.Text = text
    tab.TextSize = 12
    tab.Font = Enum.Font.GothamBold
    tab.TextColor3 = Color3.fromRGB(100, 100, 100)
    tab.Parent = tabBar
    Instance.new("UICorner", tab).CornerRadius = UDim.new(0, 4)
    return tab
end

