local function switchTab(n)
    page1.Visible = (n == 1)
    page2.Visible = (n == 2)
    page3.Visible = (n == 3)
    local tabs = {tab1, tab2, tab3}
    for i, t in ipairs(tabs) do
        t.BackgroundColor3 = (i == n) and Color3.fromRGB(70, 130, 200) or Color3.fromRGB(200, 200, 200)
        t.TextColor3 = (i == n) and Color3.new(1, 1, 1) or Color3.fromRGB(100, 100, 100)
    end
end

