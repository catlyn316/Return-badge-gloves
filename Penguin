-- 輔助：找物件下第一個 BasePart
local function getBasePart(obj)
    if obj:IsA("BasePart") then return obj end
    for _, v in ipairs(obj:GetDescendants()) do
        if v:IsA("BasePart") then return v end
    end
    return nil
end

