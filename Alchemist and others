-- 儲存 ESP 相關的參照（供後面 ESP 模組更新顏色）
local _espLabelsRef = nil  -- 由 ESP 模組設定
local _espBoxesRef  = nil

local function getPlayersInPlagueFolder()
    local count = 0
    local names = {}
    local myChar = player.Character
    if not myChar then return 0, {} end
    local plagueFolder = myChar:FindFirstChild("PlagueFolder")
    if not plagueFolder then return 0, {} end
    for _, child in pairs(plagueFolder:GetChildren()) do
        -- 子物件名稱為玩家名
        if Players:FindFirstChild(child.Name) then
            count = count + 1
            table.insert(names, child.Name)
        end
    end
    return count, names
end

local function getNearestPlayerInRange(range)
    local myChar = player.Character
    if not myChar or not myChar:FindFirstChild("HumanoidRootPart") then return nil end
    local myPos = myChar.HumanoidRootPart.Position
    local nearest, nearestDist = nil, math.huge
    for _, p in ipairs(Players:GetPlayers()) do
        if p ~= player and p.Character and p.Character:FindFirstChild("HumanoidRootPart") then
            local dist=(p.Character.HumanoidRootPart.Position - myPos).Magnitude
            if dist <= range and dist < nearestDist then nearest=p; nearestDist=dist end
        end
    end
    return nearest
end

local function fireAuraOnTarget(targetPlayer)
    if not targetPlayer or not targetPlayer.Character then return end
    local leftArm = targetPlayer.Character:FindFirstChild("Left Arm")
    if not leftArm then leftArm = targetPlayer.Character:FindFirstChild("LeftHand") end
    if leftArm then
        pcall(function()
            ReplicatedStorage.PlagueHit:FireServer(leftArm)
        end)
    end
end

local function fireAuraNearestInRange()
    local myChar = player.Character
    if not myChar or not myChar:FindFirstChild("HumanoidRootPart") then return end
    local myPos = myChar.HumanoidRootPart.Position
    local nearest, nearestDist = nil, math.huge
    for _, p in ipairs(Players:GetPlayers()) do
        if p ~= player and p.Character and p.Character:FindFirstChild("HumanoidRootPart") then
            local dist = (p.Character.HumanoidRootPart.Position - myPos).Magnitude
            if dist <= values.auraRange and dist < nearestDist then
                nearest = p; nearestDist = dist
            end
        end
    end
    if nearest then fireAuraOnTarget(nearest) end
end

-- Aura 點擊觸發（Mouse.Button1Down 每次點擊觸發，1秒冷卻）
local auraMouseConn = nil

local function startAuraClickListener()
    if auraMouseConn then auraMouseConn:Disconnect() end
    local mouse = player:GetMouse()
    auraMouseConn = mouse.Button1Down:Connect(function()
        if not auraEnabled then return end
        local now = tick()
        if now - auraLastFire < 1 then return end  -- 1秒冷卻
        auraLastFire = now
        fireAuraNearestInRange()
    end)
end

local function stopAuraClickListener()
    if auraMouseConn then auraMouseConn:Disconnect(); auraMouseConn = nil end
end

