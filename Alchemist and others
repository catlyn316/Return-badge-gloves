        plagueCountLabel.TextColor3 = Color3.fromRGB(200,200,200)
        plagueCountFrame.BackgroundColor3 = Color3.fromRGB(30,30,30)
    end

    -- 更新 ESP 顏色
    if _espLabelsRef and _espBoxesRef then
        for _, p in ipairs(Players:GetPlayers()) do
            if p ~= player then
