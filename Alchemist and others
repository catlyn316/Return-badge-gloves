RunService.Heartbeat:Connect(function()
    if not auraEnabled then
        plagueCountLabel.Text = "☣ PlagueFolder：未啟動"
        plagueCountLabel.TextColor3 = Color3.fromRGB(150,150,150)
        return
    end
    local count, names = getPlayersInPlagueFolder()
    if count > 0 then
        plagueCountLabel.Text = "☣ 感染中："..count.."人 ("..table.concat(names,", ")..")"
        plagueCountLabel.TextColor3 = Color3.fromRGB(100,255,100)
